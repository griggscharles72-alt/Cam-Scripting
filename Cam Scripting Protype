import cv2
import time
import os
from datetime import datetime

# =========================
# CONFIG
# =========================

CAMERA_URLS = [
    "http://camera1_stream_url",
    "http://camera2_stream_url",
    "http://camera3_stream_url"
]

SAVE_DIR = "captures"
RECONNECT_DELAY = 5  # seconds
FRAME_TIMEOUT = 10   # seconds without frames before reconnect

os.makedirs(SAVE_DIR, exist_ok=True)


# =========================
# CAMERA CONNECTION
# =========================

def connect_camera(url):
    cap = cv2.VideoCapture(url)
    if not cap.isOpened():
        print(f"[WARN] Could not connect: {url}")
        return None
    print(f"[INFO] Connected: {url}")
    return cap


